{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python build.py",
  "functions": {
    "app.py": {
      "maxDuration": 60,
      "memory": 2048
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "FAQ_DATA_ROOT": "/tmp/faq-assistant"
  }
}